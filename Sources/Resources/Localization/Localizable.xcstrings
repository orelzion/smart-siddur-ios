    "sefira_warning" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Siddur hat Ihren Ort als %1$@ erkannt, und Sonnenuntergang als %2$@. \nDeshalb wird das hebräische Datum als %3$@ definiert.\n\nMacht das Sinn?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Siddur detects your location as %1$@, and sunset as %2$@. \nTherefor it determines the Hebrew date as %3$@.\n\nDoes that make sense?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Siddur detects your location as %1$@, and sunset as %2$@. \nTherefor it determines the Hebrew date as %3$@.\n\nDoes that make sense?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le Siddour détecte votre position à %1$@, et le coucher du soleil à %2$@. \nEn conséquence, il détermine la date hébraïque comme étant %3$@.\n\nEtes vous d\\׳accord?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הסידור זיהה את מיקומך ב%1$@, ואת השקיעה ל %2$@. \nולכן קבע את התאריך העברי ל%3$@.\n\nזה נשמע בסדר?"
          }
        }
      }
    },
