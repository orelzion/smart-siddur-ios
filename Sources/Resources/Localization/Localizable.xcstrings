    "purchase_promotion" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n        \n        &#149; Erhalte vollen Zugang zu allen Gebeten<br/><br/>\n        &#149; Entsperre den vollen hebräischen Kalender und tägliche Zeiten<br/><br/>\n        &#149; Erhalte die volle Kotrolle in den Siddur Einstellungen<br/><br/>\n        &#149; Unterstütze den Entwickler :)\n        \n    "
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n        \n        &#149; Get full access to all prayers<br/><br/>\n        &#149; Unlock full Hebrew calendar and daily times<br/><br/>\n        &#149; Get full control on your Siddur settings<br/><br/>\n        &#149; Support the developer :)\n        \n    "
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n        \n        &#149; Obtenir un accès complet à toutes les prières<br/><br/>\n        &#149; DÈbloquer le calendrier hébraïque complet et les horaires journaliers<br/><br/>\n        &#149; Obtenir un contrôle total des paramètres de votre Siddur<br/><br/>\n        &#149; Soutenir le développeur :)\n        \n    "
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n        \n        &#149; קבל גישה מלאה לכל התפילות בסידור<br/><br/>\n        &#149; קבל גישה ללוח שנה עברי מלא וזמני היוֹם<br/><br/>\n        &#149; קבל שליטה מלאה בכל אפשרויות הסידור<br/><br/>\n        &#149; תמוך במפתח :)\n        \n    "
          }
        }
      }
    },
