    "shachritDes" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@\nLetzte Zeit um Schacharit zu beten. Man kann trotzdem bis Mittag beten (nach Meinung einiger Rabbiner), sollte aber nicht den Namen G-ttes in den Segensprüchen vor dem Schma sagen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@\nThe latest time to pray Shachrit. One can still pray until Midday (according to some rabbies) but he shouldn't say Shem in Shma blessings"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@\nÚltimo Horario para Shajrit. Hay opiniones que se puede rezar hasta Medio Día, sin embargo, sin mencionar el Shem H en las Berajot"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@\nDernier Horaire pour Prier Shahrit. On peut toujours prier jusqu’à midi (selon certains Rabbins) mais on ne devrait pas dire le Shéma ni les Bénédictions du Shéma"
          }
        }
      }
    },
