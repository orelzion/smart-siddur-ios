    "zimun" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>Si trois hommes ou plus mangent ensemble, l׳un d׳eux dit:</small><br />  הַב לָן וְנִבְרִיךְ לְמַלְכָּא עִלָּאָה קַדִּישָׁא <br />\n<small>Ils répondent:</small><br /> שָׁמַיִם <br />\n<small>Il dit:</small><br /> בִּרְשׁוּת מַלְכָּא עִלָּאָה קַדִּישָׁא, %1$@ וּבִרְשׁוּתְכֶם נְבָרֵך /<small>S\\׳il y a dix hommes:</small> אֱלֹהֵינוּ/ שֶׁאָכַלְנוּ מִשֶּׁלוֹ <br />\n<small>Ils répondent:</small><br /> בָּרוּךְ /<small>S\\׳il y dix hommes:</small> אֱלֹהֵינוּ/ שֶׁאָכַלְנוּ מִשֶּׁלוֹ וּבְטוּבוֹ חָיִינוּ <br />\n<small>A un mariage:</small><br /> בִּרְשׁוּת מַלְכָּא עִלָּאָה קַדִּישָׁא, וּבִרְשׁוּתְכֶם נְבָרֵך אֱלֹהֵינוּ שֶׁהַשִּׂמְחָה בִמְעוֹנוֹ שֶׁאָכַלְנוּ מִשֶּׁלוֹ <br />\n<small>Ils répondent:</small><br /> בָּרוּךְ אֱלֹהֵינוּ שֶׁהַשִּׂמְחָה בִמְעוֹנוֹ שֶׁאָכַלְנוּ מִשֶּׁלוֹ וּבְטוּבוֹ חָיִינוּ\n<br />\n\n"
          }
        }
      }
    },
