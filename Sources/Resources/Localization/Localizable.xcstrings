    "why_login_text" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit der Erstellung eines Accounts sind Sie in der Lage Ihre Präferenzen und Einkauf-Status in diesem Siddur zu speichern\n\n\nAbonnieren heißt NICHT, dass wir Ihnen, ohne Ihr Einverständnis, Emails senden oder, dass G-tt behüte, wir Ihre Email-Adresse an Dritte verkaufen "
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By creating an account you are able to save your preferences and purchase status with this Siddur\n\n\nSigning up does NOT mean we can send you emails without your confirmation or that g-d forbid we will sell your email address\n    to any 3rd parties"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En créant un compte, vous pourrez sauvegarder vos préférences et votre historique d׳achat de ce Siddur\n\n\nS׳enregistrer ne signifie PAS que nous vous enverrons des emails sans votre accord ni que, D.ieu nous en garde, nous vendrons votre adresse de messagerie\n    à une autre entité"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הרשמה לאפליקציה משמעה שתוכלו לשמור על ההגדרות שלכם ועל סטטוס הרכישה שלכם מכל מכשיר.\n\n זה בשום אופן לא אומר שנשלח לכם אימייל מבלי הסכמתכם או שנמכור חלילה את המידע הזה לחברות צד שלישי"
          }
        }
      }
    },
