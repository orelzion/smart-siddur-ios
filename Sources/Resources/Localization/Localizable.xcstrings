          "stringUnit" : {
            "state" : "translated",
            "value" : "Al ponerse el Tfilin de la cabeza dice:"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avant de serrer le Téphiline de la tête, on dit la bénédiction"
