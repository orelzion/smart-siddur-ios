    "shmaZizit" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>(Nehme die vorderen zwei Tzitzit in deine rechte Hand, dann dein hinteres linkes, dann dein hinteres rechtes Tzitzit. Sie werden alle in die linke Hand gelegt und am Herzen gehoben)\n</small>\n\n    "
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>(Take the two front tzitzit into your right hand, then your back left tzitzit, then the back right. Then the tzitzit are moved to the left hand and held near the heart)\n</small>\n\n    "
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>(Tome los 2 Tzitzit del frente en su mano derecha, luego el tzitzit de atrás izquierdo, luego el de atrás derecho. Luego se toman con la mano izquierda y se sostienen junto al Corazón)\n</small>\n\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>(Prendre avec la main droite les deux tzitzit de devant, puis les deux de derrière à gauche, puis l׳arrière droit. Puis les tzitzit sont mis dans la main gauche et tenus près du coeur)\n</small>\n\n"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n<small>(החזק את כל הציציות ביד שמאל)\n</small>\n\n"
          }
        }
      }
    },
