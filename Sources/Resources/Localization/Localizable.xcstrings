    "mezonotBlessTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bevor man etwas aus Weizen, Gerste, Hafer, Roggen oder Dinkel isst, sagt man:   "
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Before eating anything made of wheat, barley, oats, rye, or spelt one should say:   "
