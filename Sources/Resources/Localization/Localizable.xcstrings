    "mineiTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vor dem Riechen oder über das Riechen eines Duftes, das (a) eine Mischung aus Gewürzen verschiedenen Ursprungs ist, oder (b) eines nicht-pflanzlichen Ursprungs ist (z.B. synthetische Parfüme),\noder (c) eines unbestimmten Ursprungs ist:"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When preparing to smell or upon smelling fragrances that are (a) a blend of spices of different origins, or (b) of non-vegetable origins (e.g. synthetic perfumes),\nor (c) of undetermined origin:"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " Cuando se prepare para oler o al oler fragancias que son (1) una mezcla de especias de diferentes orígenes, o (2) de los orígenes no vegetales (por ejemplo, perfumes sintéticos),\no (3), de origen indeterminado:"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque l׳on se prépare à sentir ou lorsque l׳on sent le parfum provenant (a) d׳un mélange d׳épices de différentes origines, ou (b) d\\׳origine non végétale (ex. parfums synthétiques),\nou (c) d\\׳origine indéterminée:"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בהרחת דברים שלא ידוע מקורם, או שאין מקורם בהצומח או שהם ממינים מעורבים:"
          }
        }
      }
    },
